# Copy to .env and fill in real values. Never commit .env.
SCHWAB_APP_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here
SCHWAB_CALLBACK_URL=https://127.0.0.1

# Financial Modeling Prep (FMP) — used for short-interest data.
# Premium plan or higher required for /api/v4/short-interest.
# If unset or the call fails, the scanner falls back to yfinance.
FMP_API_KEY=