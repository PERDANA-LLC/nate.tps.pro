# Schwab API Configuration
SCHWAB_CLIENT_ID=your_client_id_here
SCHWAB_CLIENT_SECRET=your_client_secret_here
SCHWAB_CALLBACK_URL=http://localhost:8000/callback
SCHWAB_AUTH_MODE=sandbox  # sandbox or live

# Database
DATABASE_URL=sqlite:///./options_detective.db
# For PostgreSQL: postgresql://user:pass@localhost/optionsdetective

# Trading Parameters
PAPER_TRADING_MODE=True
INITIAL_BALANCE=10000.00
MAX_POSITION_SIZE=0.05  # 5% of portfolio per position
MAX_DAILY_LOSS=0.02  # 2% daily loss limit
RISK_FREE_RATE=0.05  # 5% annual

# Discord Alerts (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# App Settings
SECRET_KEY=change_this_in_production
DEBUG=True
HOST=0.0.0.0
PORT=8000
